	<test thread-count="5" name="Submit Order Test">
		<classes>
			<class name="RahulShetty.SeleniumFrameworkDesign_R.SubmitOrderTest" />

		</classes>
	</test>
	<test thread-count="5" name="ErrorValidation Test">
		<classes>

			<class
				name="RahulShetty.SeleniumFrameworkDesign_R.ErrorValidationsTest" />
		</classes>
	</test> <!--
	Test -->
</suite> <!--
Suite -->
